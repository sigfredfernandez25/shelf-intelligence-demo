# Shelf Intelligence Agent Configuration
# Copy this file to .env.local and update values for your environment

# Application Settings
NEXT_PUBLIC_APP_NAME="Shelf Intelligence Agent"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# API Configuration
API_BASE_URL="http://localhost:3000/api"
AGENT_TIMEOUT_MS=30000

# Agent Configuration
FORECAST_CONFIDENCE_THRESHOLD=85
MAX_SUBSTITUTE_RECOMMENDATIONS=3
TASK_PRIORITY_WEIGHTS='{"Critical":4,"High":3,"Medium":2,"Low":1}'

# Enterprise Integration
# COPILOT_STUDIO_ENDPOINT=""
# AZURE_AI_FOUNDRY_ENDPOINT=""
# OPENAPI_SERVER_URL="https://your-domain.vercel.app"

# Monitoring and Logging
LOG_LEVEL="info"
ENABLE_AGENT_METRICS=true
PERFORMANCE_MONITORING=true

# Security (Production)
# JWT_SECRET="your-jwt-secret"
# API_KEY="your-api-key"
# CORS_ORIGINS="https://your-domain.com,https://your-copilot.microsoft.com"

# Database (Future Integration)
# DATABASE_URL="postgresql://username:password@hostname:port/database"
# REDIS_URL="redis://localhost:6379"

# External Services (Future Integration)  
# POS_API_ENDPOINT=""
# ERP_API_ENDPOINT=""
# INVENTORY_API_ENDPOINT=""